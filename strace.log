ir) || '/';\n    }\n    1;\n}\n\nsub _perl_abs_path\n{\n    my $start = @_ ? shift : '.';\n    my($dotdots, $cwd, @pst, @cst, $dir, @tst);\n\n    unless (@cst = stat( $start ))\n    {\n\tre"..., 8192) = 8192
