read(10, "#!/bin/sh\nif [ \"$1\" = 'config' ] || [ \"$1\" = 'version' ]; then\n  /tmp/.check-spelling-git-logs/git \"$@\" 2> /dev/null\n  exit $?\nfi\n\nsha=$(echo \"${repo_path:-$(pwd)}\"|shasum|perl -pe 's/\\s.*//')\ngit_logs=/tmp/.check-spelling-git-logs/${sha%* -}\n\nmkdir -p \"$git_logs\"\nout=\"${checkout_git_out:-$git_logs/out}\"\nerr=\"${checkout_git_err:-$git_logs/err}\"\n(\n  echo \"err=$err\"\n  echo \"out=$out\"\n) >> \"$GITHUB_OUTPUT\"\ntouch \"$err\"\n\n(\n  log=\"$(mktemp)\"\n  /tmp/.check-spelling-git-logs/git \"$@\" 2> \"$log\"\n  result=$?\n  if [ $result -ne 0 ]; then\n    cat \"$log\" | tee -a \"$err\" >&2\n  fi\n  exit $result\n) | tee -a \"$out\"\n", 8192) = 606
